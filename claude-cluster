#!/usr/bin/env bash

# claude-cluster: Manage multiple Claude Code instances
# Usage: claude-cluster <command> [options]

set -euo pipefail

# Configuration
CLUSTER_DIR="$HOME/.claude/cluster"
SESSIONS_FILE="$CLUSTER_DIR/sessions.json"
WORKTREE_BASE="$HOME/.claude/cluster/worktrees"
COORDINATION_DIR="$CLUSTER_DIR/coordination"
CLAUDE_BIN="claude"

# Resolve the repo dir via the symlink so we can find prompts/.
# Use BASH_SOURCE (not $0) so REPO_DIR is correct when the script is sourced for tests.
SCRIPT_PATH=$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
REPO_DIR=$(dirname "$SCRIPT_PATH")

# Bump when sessions.json layout changes; add a corresponding block in migrate_sessions.
SCHEMA_VERSION=1

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if jq is available
check_jq() {
    if ! command -v jq &> /dev/null; then
        log_error "jq is required but not installed. Install with: brew install jq"
        exit 1
    fi
}

# Initialize sessions file if it doesn't exist (fresh installs jump straight to current schema)
init_sessions() {
    if [[ ! -f "$SESSIONS_FILE" ]]; then
        mkdir -p "$CLUSTER_DIR"
        jq -n --argjson v "$SCHEMA_VERSION" '{schema_version: $v, sessions: []}' > "$SESSIONS_FILE"
    fi
}

# Apply pending data migrations to bring sessions.json up to SCHEMA_VERSION.
# Fresh installs skip this entirely (init_sessions writes the latest layout).
migrate_sessions() {
    [[ ! -f "$SESSIONS_FILE" ]] && return 0

    local current
    current=$(jq -r '.schema_version // 0' "$SESSIONS_FILE" 2>/dev/null || echo 0)

    if (( current >= SCHEMA_VERSION )); then
        return 0
    fi

    log_info "Migrating sessions data: v$current -> v$SCHEMA_VERSION"

    if (( current < 1 )); then
        # 0 -> 1: introduce schema_version field on pre-versioned data
        jq --argjson v 1 '. + {schema_version: $v}' "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp" \
            && mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
    fi

    # Future migrations go here, each guarded by `if (( current < N ))`.
    # Each block must be idempotent and bump nothing else.

    log_success "Migration complete (now at v$SCHEMA_VERSION)"
}

# Validate session name
validate_session_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        log_error "Invalid session name. Use only alphanumeric characters, hyphens, and underscores."
        exit 1
    fi
}

# Check if session name already exists
session_exists() {
    local name="$1"
    jq -e ".sessions[] | select(.name == \"$name\")" "$SESSIONS_FILE" > /dev/null 2>&1
}

# Check if process is running
is_process_running() {
    local pid="$1"
    ps -p "$pid" > /dev/null 2>&1
}

# Add session to sessions.json. Optional 5th arg: parent fanout name (for workers/QA).
add_session() {
    local name="$1"
    local pid="$2"
    local branch="$3"
    local working_dir="$4"
    local parent="${5:-}"
    local started
    started=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local new_session
    if [[ -n "$parent" ]]; then
        new_session=$(jq -n \
            --arg name "$name" --arg pid "$pid" --arg branch "$branch" \
            --arg dir "$working_dir" --arg started "$started" --arg parent "$parent" \
            '{name: $name, pid: ($pid|tonumber), branch: $branch, working_dir: $dir, started: $started, parent: $parent}')
    else
        new_session=$(jq -n \
            --arg name "$name" --arg pid "$pid" --arg branch "$branch" \
            --arg dir "$working_dir" --arg started "$started" \
            '{name: $name, pid: ($pid|tonumber), branch: $branch, working_dir: $dir, started: $started}')
    fi

    jq ".sessions += [$new_session]" "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp"
    mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
}

# Substitute {placeholder} markers in a template file with provided values.
# Usage: substitute_template <template-path> key1 value1 key2 value2 ...
# Uses bash literal substitution (no regex), so values can contain anything.
substitute_template() {
    local template_file="$1"
    shift
    if [[ ! -f "$template_file" ]]; then
        log_error "Template not found: $template_file"
        return 1
    fi
    local content
    content=$(<"$template_file")
    while [[ $# -ge 2 ]]; do
        local key="$1" value="$2"
        content=${content//"{$key}"/"$value"}
        shift 2
    done
    printf '%s' "$content"
}

# Remove session from sessions.json
remove_session() {
    local name="$1"
    jq "del(.sessions[] | select(.name == \"$name\"))" "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp"
    mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
}

# Get session by name
get_session() {
    local name="$1"
    jq -r ".sessions[] | select(.name == \"$name\")" "$SESSIONS_FILE"
}

# Clean up stale sessions
cleanup_stale_sessions() {
    local stale_count=0
    local sessions=$(jq -r '.sessions[] | @json' "$SESSIONS_FILE")

    while IFS= read -r session; do
        local pid=$(echo "$session" | jq -r '.pid')
        local name=$(echo "$session" | jq -r '.name')

        if ! is_process_running "$pid"; then
            log_warn "Removing stale session: $name (PID $pid)"
            remove_session "$name"
            ((stale_count++))
        fi
    done <<< "$sessions"

    if [[ $stale_count -gt 0 ]]; then
        log_info "Cleaned up $stale_count stale session(s)"
    fi
}

# Command: start
cmd_start() {
    local name=""
    local branch=""
    local auto_branch=false
    local orchestrate=false
    local working_dir="$PWD"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -b|--branch)
                branch="$2"
                shift 2
                ;;
            --auto-branch)
                auto_branch=true
                shift
                ;;
            --orchestrate)
                orchestrate=true
                shift
                ;;
            -d|--dir)
                working_dir="$2"
                shift 2
                ;;
            *)
                name="$1"
                shift
                ;;
        esac
    done

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster start <name> [--branch <branch>] [--auto-branch] [--orchestrate] [--dir <directory>]"
        exit 1
    fi

    if [[ "$orchestrate" == true && ! -f "$REPO_DIR/prompts/orchestrate.md" ]]; then
        log_error "Orchestration prompt missing: $REPO_DIR/prompts/orchestrate.md"
        log_info "Reinstall via the cloned repo if you copied claude-cluster manually."
        exit 1
    fi

    validate_session_name "$name"

    if session_exists "$name"; then
        log_error "Session '$name' already exists. Use 'claude-cluster kill $name' first."
        exit 1
    fi

    # Check if directory exists
    if [[ ! -d "$working_dir" ]]; then
        log_error "Directory does not exist: $working_dir"
        exit 1
    fi

    # Handle git branch with worktrees for true isolation
    local use_worktree=false
    local worktree_dir=""

    if [[ -d "$working_dir/.git" ]] || git -C "$working_dir" rev-parse --git-dir > /dev/null 2>&1; then
        local git_root=$(cd "$working_dir" && git rev-parse --show-toplevel)
        local current_branch=$(cd "$working_dir" && git branch --show-current)

        if [[ "$auto_branch" == true ]]; then
            branch="claude/$name"
            log_info "Auto-creating branch: $branch"
        fi

        if [[ -n "$branch" ]]; then
            use_worktree=true

            # Create worktree directory structure: ~/.claude/cluster/worktrees/<repo-name>/<branch-name>
            local repo_name=$(basename "$git_root")
            worktree_dir="$WORKTREE_BASE/$repo_name/$name"

            log_info "Creating isolated worktree for branch: $branch"
            log_info "Worktree location: $worktree_dir"

            # Create worktree base directory
            mkdir -p "$(dirname "$worktree_dir")"

            # Check if branch exists
            if (cd "$git_root" && git show-ref --verify --quiet "refs/heads/$branch"); then
                log_info "Using existing branch: $branch"
                # Create worktree with existing branch
                (cd "$git_root" && git worktree add "$worktree_dir" "$branch")
            else
                log_info "Creating new branch: $branch"
                # Create worktree with new branch
                (cd "$git_root" && git worktree add -b "$branch" "$worktree_dir")
            fi

            # Update working_dir to point to worktree
            working_dir="$worktree_dir"
        else
            branch="$current_branch"
            log_warn "No branch specified, using current branch in shared directory"
            log_warn "For true isolation, use --auto-branch or --branch"
        fi
    else
        branch="N/A"
        log_warn "Not a git repository: $working_dir"
    fi

    # Launch Claude in the working directory
    log_info "Launching Claude instance: $name"
    log_info "Working directory: $working_dir"
    log_info "Branch: $branch"

    # Build optional --append-system-prompt-file flag for orchestrate mode
    local sysprompt_flag=""
    local mode_label=""
    if [[ "$orchestrate" == true ]]; then
        sysprompt_flag="--append-system-prompt-file '$REPO_DIR/prompts/orchestrate.md'"
        mode_label=" (orchestrator)"
        log_info "Orchestration mode enabled — Claude can spawn fanouts/QA workers"
    fi

    # Use osascript to open new Terminal window/tab
    if [[ "$TERM_PROGRAM" == "Apple_Terminal" ]] || command -v osascript &> /dev/null; then
        osascript <<EOF
tell application "Terminal"
    do script "cd '$working_dir' && echo 'Claude Cluster Session: $name$mode_label' && echo 'Branch: $branch' && echo '' && $CLAUDE_BIN $sysprompt_flag --model claude-opus-4-7 --dangerously-skip-permissions"
    activate
end tell
EOF
        # Give the terminal a moment to start and get the PID
        sleep 1

        # Find the most recent Claude process
        local claude_pid=$(pgrep -n "claude")

        if [[ -z "$claude_pid" ]]; then
            log_error "Failed to find Claude process. Session may not have started correctly."
            exit 1
        fi

        add_session "$name" "$claude_pid" "$branch" "$working_dir"
        log_success "Started session '$name' (PID: $claude_pid)"
    else
        log_error "Terminal automation not supported. Please launch Claude manually."
        exit 1
    fi
}

# Command: list
cmd_list() {
    cleanup_stale_sessions

    local sessions=$(jq -r '.sessions' "$SESSIONS_FILE")
    local count=$(echo "$sessions" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
        log_info "No active sessions"
        exit 0
    fi

    echo ""
    printf "%-20s %-10s %-30s %-25s %s\n" "NAME" "PID" "BRANCH" "STARTED" "WORKING DIR"
    printf "%-20s %-10s %-30s %-25s %s\n" "----" "---" "------" "-------" "-----------"

    echo "$sessions" | jq -r '.[] | [.name, .pid, .branch, .started, .working_dir] | @tsv' | \
    while IFS=$'\t' read -r name pid branch started dir; do
        printf "%-20s %-10s %-30s %-25s %s\n" "$name" "$pid" "$branch" "$started" "$dir"
    done

    echo ""
    log_info "Total active sessions: $count"
}

# Command: kill
cmd_kill() {
    local name="$1"
    local force=false

    if [[ "$name" == "--all" ]]; then
        # Kill all sessions
        local sessions=$(jq -r '.sessions[] | @json' "$SESSIONS_FILE")
        local count=0

        while IFS= read -r session; do
            if [[ -z "$session" ]]; then
                continue
            fi

            local session_name=$(echo "$session" | jq -r '.name')
            # Use the full kill logic for each session to clean up worktrees
            cmd_kill "$session_name" 2>/dev/null || true
            ((count++))
        done <<< "$sessions"

        log_success "Killed $count session(s)"
        exit 0
    fi

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster kill <name|--all>"
        exit 1
    fi

    # Fanout? Kill every child session, then remove the coordination dir.
    if is_fanout "$name"; then
        local children
        children=$(jq -r --arg parent "$name" '.sessions[] | select(.parent == $parent) | .name' "$SESSIONS_FILE" 2>/dev/null || true)
        local count=0
        if [[ -n "$children" ]]; then
            while IFS= read -r child; do
                [[ -z "$child" ]] && continue
                cmd_kill "$child" 2>/dev/null || true
                ((count++))
            done <<< "$children"
        fi
        log_info "Removing fanout coordination dir: $COORDINATION_DIR/$name"
        rm -rf "$COORDINATION_DIR/$name"
        log_success "Fanout '$name' killed ($count workers/QA)"
        return 0
    fi

    if ! session_exists "$name"; then
        log_error "Session '$name' not found"
        exit 1
    fi

    local session=$(get_session "$name")
    local pid=$(echo "$session" | jq -r '.pid')
    local working_dir=$(echo "$session" | jq -r '.working_dir')

    if is_process_running "$pid"; then
        log_info "Killing session '$name' (PID $pid)"
        kill "$pid" 2>/dev/null || log_error "Failed to kill process $pid"
        sleep 1

        if is_process_running "$pid"; then
            log_warn "Process still running, sending SIGKILL"
            kill -9 "$pid" 2>/dev/null
        fi

        log_success "Session '$name' terminated"
    else
        log_warn "Process $pid is not running"
    fi

    # Clean up worktree if it was used
    if [[ "$working_dir" == "$WORKTREE_BASE"* ]]; then
        log_info "Removing worktree: $working_dir"

        # Find the git root for this worktree
        if [[ -d "$working_dir" ]] && git -C "$working_dir" rev-parse --git-dir > /dev/null 2>&1; then
            local git_root=$(cd "$working_dir" && git rev-parse --show-toplevel 2>/dev/null || true)
            local git_common_dir=$(cd "$working_dir" && git rev-parse --git-common-dir 2>/dev/null || true)

            # Get the main repository directory
            if [[ -n "$git_common_dir" ]]; then
                local main_repo=$(dirname "$git_common_dir")
                (cd "$main_repo" && git worktree remove "$working_dir" --force 2>/dev/null || rm -rf "$working_dir")
            fi
        else
            # Worktree directory exists but git is gone, just remove it
            rm -rf "$working_dir"
        fi

        log_success "Worktree cleaned up"
    fi

    remove_session "$name"
}

# Helper: name refers to an existing fanout (has a coordination dir + meta.json)
is_fanout() {
    [[ -d "$COORDINATION_DIR/$1" && -f "$COORDINATION_DIR/$1/meta.json" ]]
}

# Command: fanout — spawn N parallel workers, each in its own worktree
cmd_fanout() {
    local name=""
    local task=""
    local -a approaches=()
    local base=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --task) task="$2"; shift 2 ;;
            --approach) approaches+=("$2"); shift 2 ;;
            --base) base="$2"; shift 2 ;;
            *) name="$1"; shift ;;
        esac
    done

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster fanout <name> --task \"<task>\" --approach \"<a1>\" [--approach \"<a2>\" ...]"
        exit 1
    fi
    validate_session_name "$name"
    if [[ -z "$task" ]]; then
        log_error "--task is required"
        exit 1
    fi
    if (( ${#approaches[@]} < 1 )); then
        log_error "at least one --approach is required (typical: 2-4)"
        exit 1
    fi
    if (( ${#approaches[@]} > 6 )); then
        log_warn "Spawning ${#approaches[@]} workers — token cost will scale linearly."
    fi
    if [[ ! -f "$REPO_DIR/prompts/worker.md" ]]; then
        log_error "Worker prompt missing: $REPO_DIR/prompts/worker.md"
        exit 1
    fi
    if is_fanout "$name"; then
        log_error "Fanout '$name' already exists. Kill it first: claude-cluster kill $name"
        exit 1
    fi

    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        log_error "Run fanout from inside a git repo (we branch off your current branch)."
        exit 1
    fi

    local git_root repo_name
    git_root=$(git rev-parse --show-toplevel)
    repo_name=$(basename "$git_root")

    if [[ -z "$base" ]]; then
        base=$(git branch --show-current)
        if [[ -z "$base" ]]; then
            log_error "Could not determine current branch; pass --base explicitly."
            exit 1
        fi
    fi

    local coord_root="$COORDINATION_DIR/$name"
    mkdir -p "$coord_root"

    local approaches_json
    approaches_json=$(printf '%s\n' "${approaches[@]}" | jq -R . | jq -s .)
    jq -n \
        --arg name "$name" --arg task "$task" --arg base "$base" \
        --arg git_root "$git_root" --arg repo_name "$repo_name" \
        --argjson approaches "$approaches_json" \
        --arg started "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
        '{type: "fanout", name: $name, task: $task, base: $base, git_root: $git_root, repo_name: $repo_name, approaches: $approaches, started: $started}' \
        > "$coord_root/meta.json"

    log_info "Fanout '$name': base=$base, ${#approaches[@]} workers"

    local i=1
    for approach in "${approaches[@]}"; do
        local worker_name="${name}-w${i}"
        local worker_branch="claude/${worker_name}"
        local worker_worktree="$WORKTREE_BASE/$repo_name/$worker_name"
        local worker_coord="$coord_root/worker-$i"

        mkdir -p "$worker_coord"
        echo "starting" > "$worker_coord/status"
        printf '%s' "$approach" > "$worker_coord/approach.txt"

        log_info "  worker $i: $worker_branch -> $worker_worktree"

        if (cd "$git_root" && git show-ref --verify --quiet "refs/heads/$worker_branch"); then
            (cd "$git_root" && git worktree add "$worker_worktree" "$worker_branch") > /dev/null 2>&1
        else
            (cd "$git_root" && git worktree add -b "$worker_branch" "$worker_worktree" "$base") > /dev/null 2>&1
        fi

        substitute_template "$REPO_DIR/prompts/worker.md" \
            worker_index "$i" \
            worker_count "${#approaches[@]}" \
            worktree "$worker_worktree" \
            branch "$worker_branch" \
            base_branch "$base" \
            coordination_dir "$worker_coord" \
            approach "$approach" \
            > "$worker_coord/system-prompt.md"

        # Spawn worker in background; -p mode runs non-interactively and exits when done.
        (
            cd "$worker_worktree" || { echo "failed-cd" > "$worker_coord/status"; exit 1; }
            echo "running" > "$worker_coord/status"
            "$CLAUDE_BIN" -p "$task" \
                --append-system-prompt-file "$worker_coord/system-prompt.md" \
                --model claude-opus-4-7 \
                --dangerously-skip-permissions \
                > "$worker_coord/output.log" 2>&1
            local rc=$?
            if [[ $rc -eq 0 ]]; then
                echo "done" > "$worker_coord/status"
            else
                echo "failed" > "$worker_coord/status"
            fi
        ) &
        local worker_pid=$!

        add_session "$worker_name" "$worker_pid" "$worker_branch" "$worker_worktree" "$name"
        ((i++))
    done

    log_success "Fanout '$name' launched: ${#approaches[@]} workers running in background"
    log_info "Watch:        claude-cluster status $name"
    log_info "Coordination: $coord_root"
}

# Command: qa — spawn a fresh-eyes reviewer over a branch produced by a fanout
cmd_qa() {
    local fanout_name=""
    local branch=""
    local task=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --branch) branch="$2"; shift 2 ;;
            --task) task="$2"; shift 2 ;;
            *) fanout_name="$1"; shift ;;
        esac
    done

    if [[ -z "$fanout_name" || -z "$branch" || -z "$task" ]]; then
        log_error "Usage: claude-cluster qa <fanout-name> --branch <branch> --task \"<criteria>\""
        exit 1
    fi
    validate_session_name "$fanout_name"
    if ! is_fanout "$fanout_name"; then
        log_error "Fanout '$fanout_name' not found at $COORDINATION_DIR/$fanout_name"
        exit 1
    fi
    if [[ ! -f "$REPO_DIR/prompts/qa.md" ]]; then
        log_error "QA prompt missing: $REPO_DIR/prompts/qa.md"
        exit 1
    fi

    local coord_root="$COORDINATION_DIR/$fanout_name"
    local meta_file="$coord_root/meta.json"
    local git_root base repo_name
    git_root=$(jq -r '.git_root' "$meta_file")
    base=$(jq -r '.base' "$meta_file")
    repo_name=$(jq -r '.repo_name' "$meta_file")

    if ! (cd "$git_root" && git show-ref --verify --quiet "refs/heads/$branch"); then
        log_error "Branch '$branch' not found in $git_root"
        exit 1
    fi

    local qa_session_name="${fanout_name}-qa"
    if session_exists "$qa_session_name"; then
        log_error "QA already running for '$fanout_name'. Kill first: claude-cluster kill $qa_session_name"
        exit 1
    fi

    local qa_worktree="$WORKTREE_BASE/$repo_name/$qa_session_name"
    local qa_coord="$coord_root/qa"
    mkdir -p "$qa_coord"
    echo "starting" > "$qa_coord/status"
    printf '%s' "$branch" > "$qa_coord/branch.txt"
    printf '%s' "$task" > "$qa_coord/criteria.txt"

    log_info "QA: reviewing $branch (against $base) for fanout '$fanout_name'"
    (cd "$git_root" && git worktree add "$qa_worktree" "$branch") > /dev/null 2>&1

    substitute_template "$REPO_DIR/prompts/qa.md" \
        worktree "$qa_worktree" \
        branch "$branch" \
        base_branch "$base" \
        coordination_dir "$qa_coord" \
        > "$qa_coord/system-prompt.md"

    (
        cd "$qa_worktree" || { echo "failed-cd" > "$qa_coord/status"; exit 1; }
        echo "running" > "$qa_coord/status"
        "$CLAUDE_BIN" -p "$task" \
            --append-system-prompt-file "$qa_coord/system-prompt.md" \
            --model claude-opus-4-7 \
            --dangerously-skip-permissions \
            > "$qa_coord/output.log" 2>&1
        local rc=$?
        if [[ $rc -eq 0 ]]; then
            echo "done" > "$qa_coord/status"
        else
            echo "failed" > "$qa_coord/status"
        fi
    ) &
    local qa_pid=$!

    add_session "$qa_session_name" "$qa_pid" "$branch" "$qa_worktree" "$fanout_name"
    log_success "QA launched: $qa_session_name (PID $qa_pid)"
    log_info "Watch: claude-cluster status $fanout_name"
}

# Helper: emit JSON describing fanout state (workers + QA + meta)
cmd_status_fanout() {
    local name="$1"
    local coord_root="$COORDINATION_DIR/$name"
    local meta_file="$coord_root/meta.json"

    local workers="[]"
    local worker_dir
    for worker_dir in "$coord_root"/worker-*; do
        [[ -d "$worker_dir" ]] || continue
        local idx="${worker_dir##*-}"
        local worker_session_name="${name}-w${idx}"

        local status="unknown"
        [[ -f "$worker_dir/status" ]] && status=$(cat "$worker_dir/status")

        local pid="" branch="" worktree=""
        if session_exists "$worker_session_name"; then
            local s
            s=$(get_session "$worker_session_name")
            pid=$(echo "$s" | jq -r '.pid')
            branch=$(echo "$s" | jq -r '.branch')
            worktree=$(echo "$s" | jq -r '.working_dir')
            if [[ "$status" == "running" ]] && ! is_process_running "$pid"; then
                status="terminated"
                echo "$status" > "$worker_dir/status"
            fi
        fi

        local approach=""
        [[ -f "$worker_dir/approach.txt" ]] && approach=$(cat "$worker_dir/approach.txt")
        local summary_path="$worker_dir/summary.md"
        local summary_exists=false
        [[ -f "$summary_path" ]] && summary_exists=true

        workers=$(echo "$workers" | jq \
            --arg idx "$idx" --arg status "$status" --arg pid "$pid" \
            --arg branch "$branch" --arg worktree "$worktree" --arg approach "$approach" \
            --arg summary_path "$summary_path" --argjson summary_exists "$summary_exists" \
            '. + [{index: ($idx|tonumber), status: $status, pid: $pid, branch: $branch, worktree: $worktree, approach: $approach, summary_path: $summary_path, summary_exists: $summary_exists}]')
    done

    local qa_obj='null'
    if [[ -d "$coord_root/qa" ]]; then
        local qa_session_name="${name}-qa"
        local qa_status="unknown"
        [[ -f "$coord_root/qa/status" ]] && qa_status=$(cat "$coord_root/qa/status")
        local qa_pid=""
        if session_exists "$qa_session_name"; then
            qa_pid=$(get_session "$qa_session_name" | jq -r '.pid')
            if [[ "$qa_status" == "running" ]] && ! is_process_running "$qa_pid"; then
                qa_status="terminated"
                echo "$qa_status" > "$coord_root/qa/status"
            fi
        fi
        local qa_branch=""
        [[ -f "$coord_root/qa/branch.txt" ]] && qa_branch=$(cat "$coord_root/qa/branch.txt")
        local qa_summary_path="$coord_root/qa/summary.md"
        local qa_summary_exists=false
        [[ -f "$qa_summary_path" ]] && qa_summary_exists=true
        qa_obj=$(jq -n \
            --arg status "$qa_status" --arg pid "$qa_pid" --arg branch "$qa_branch" \
            --arg summary_path "$qa_summary_path" --argjson summary_exists "$qa_summary_exists" \
            '{status: $status, pid: $pid, branch: $branch, summary_path: $summary_path, summary_exists: $summary_exists}')
    fi

    jq -n \
        --argjson meta "$(cat "$meta_file")" \
        --argjson workers "$workers" \
        --argjson qa "$qa_obj" \
        --arg coord "$coord_root" \
        '{type: "fanout", meta: $meta, workers: $workers, qa: $qa, coordination_dir: $coord}'
}

# Command: status
cmd_status() {
    local name="$1"

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster status <name>"
        exit 1
    fi

    # Fanout? Emit JSON for the orchestrator to parse.
    if is_fanout "$name"; then
        cmd_status_fanout "$name"
        return
    fi

    if ! session_exists "$name"; then
        log_error "Session or fanout '$name' not found"
        exit 1
    fi

    local session=$(get_session "$name")
    local pid=$(echo "$session" | jq -r '.pid')
    local branch=$(echo "$session" | jq -r '.branch')
    local started=$(echo "$session" | jq -r '.started')
    local dir=$(echo "$session" | jq -r '.working_dir')
    local parent=$(echo "$session" | jq -r '.parent // empty')

    echo ""
    echo "Session: $name"
    echo "PID: $pid"
    echo "Branch: $branch"
    echo "Started: $started"
    echo "Working Dir: $dir"
    [[ -n "$parent" ]] && echo "Parent fanout: $parent"
    echo "Status: $(is_process_running "$pid" && echo "Running" || echo "Not Running")"
    echo ""
}

# Command: update — pull the repo and re-exec under the new code so migrations apply
cmd_update() {
    local script_path repo
    script_path=$(realpath "$0" 2>/dev/null || echo "$0")
    repo=$(dirname "$script_path")

    if ! git -C "$repo" rev-parse --git-dir > /dev/null 2>&1; then
        log_error "Not installed from a git clone (no repo at $repo)"
        log_info  "If you installed by copying the script, pull updates manually."
        exit 1
    fi

    if ! git -C "$repo" diff --quiet 2>/dev/null || ! git -C "$repo" diff --cached --quiet 2>/dev/null; then
        log_warn "Repo has uncommitted changes; refusing to pull"
        log_info "Resolve them in $repo and re-run: claude-cluster update"
        exit 1
    fi

    log_info "Pulling updates from $repo"
    git -C "$repo" pull --ff-only

    log_info "Reloading to apply data migrations..."
    exec "$0" __post_update
}

# Command: help
cmd_help() {
    cat <<EOF
claude-cluster - Manage multiple Claude Code instances

USAGE:
    claude-cluster <command> [options]

COMMANDS:
    start <name>              Start a new Claude instance with given name
        --branch <branch>     Checkout specific git branch (creates isolated worktree)
        --auto-branch         Auto-create branch claude/<name> (creates isolated worktree)
        --orchestrate         Enable orchestration: Claude can spawn fanouts/QA itself
        --dir <directory>     Set working directory (default: current)

    list                      List all active sessions (including fanout workers)

    kill <name>               Terminate a session OR a fanout (kills its workers + cleans up coord dir)
    kill --all                Terminate all sessions (cleans up all worktrees)

    status <name>             Show details of a session (human-readable) OR fanout (JSON)

    fanout <name>             Spawn N parallel workers, each in its own worktree
        --task "<task>"       The task all workers must accomplish (required)
        --approach "<hint>"   Approach hint for one worker (repeatable; one per worker)
        --base <branch>       Base branch to fork from (default: current branch)

    qa <fanout-name>          Spawn a fresh-eyes reviewer over a branch from a fanout
        --branch <branch>     Branch to review (required)
        --task "<criteria>"   Review criteria (required)

    update                    Pull the latest version of claude-cluster and apply
                              any pending data migrations (requires git-clone install)

    help                      Show this help message

EXAMPLES:
    # Start instance with auto-created branch (RECOMMENDED - creates isolated worktree)
    claude-cluster start feature-auth --auto-branch

    # Start instance with orchestration capability (Claude can spawn parallel workers)
    claude-cluster start big-task --auto-branch --orchestrate

    # Manual fanout: explore three approaches in parallel
    claude-cluster fanout retry-design \\
        --task "implement payment retry logic" \\
        --approach "exponential backoff with jitter" \\
        --approach "fixed retry with circuit breaker" \\
        --approach "queue-based retry with workers"

    # Watch a fanout (returns JSON)
    claude-cluster status retry-design

    # Spawn QA reviewer over a worker's branch
    claude-cluster qa retry-design --branch claude/retry-design-w1 --task "race conditions and error handling"

    # Kill a fanout (terminates all workers, removes coord dir)
    claude-cluster kill retry-design

WORKTREES:
    When using --branch or --auto-branch, claude-cluster creates a git worktree
    at ~/.claude/cluster/worktrees/<repo>/<name>/ for true branch isolation.
    Fanout workers each get their own worktree under the same path.

ORCHESTRATION:
    Sessions started with --orchestrate get a system prompt extension allowing
    them to call \`claude-cluster fanout\`, \`status\`, \`qa\`, and \`kill\` themselves
    when a task warrants parallel exploration. Workers do NOT get the flag, so
    recursion is bounded by design.

MORE INFO:
    See README.md in the claude-cluster repository for detailed documentation

EOF
}

# Main command dispatcher
main() {
    check_jq
    init_sessions
    migrate_sessions

    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 0
    fi

    local command="$1"
    shift

    case "$command" in
        start)
            cmd_start "$@"
            ;;
        list|ls)
            cmd_list "$@"
            ;;
        kill|stop)
            cmd_kill "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        fanout)
            cmd_fanout "$@"
            ;;
        qa)
            cmd_qa "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        __post_update)
            log_success "Update complete (schema v$SCHEMA_VERSION)"
            exit 0
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

# Only run main when invoked directly (not when sourced for testing).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
