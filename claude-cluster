#!/usr/bin/env bash

# claude-cluster: Manage multiple Claude Code instances
# Usage: claude-cluster <command> [options]

set -euo pipefail

# Configuration
CLUSTER_DIR="$HOME/.claude/cluster"
SESSIONS_FILE="$CLUSTER_DIR/sessions.json"
WORKTREE_BASE="$HOME/.claude/cluster/worktrees"
CLAUDE_BIN="claude"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if jq is available
check_jq() {
    if ! command -v jq &> /dev/null; then
        log_error "jq is required but not installed. Install with: brew install jq"
        exit 1
    fi
}

# Initialize sessions file if it doesn't exist
init_sessions() {
    if [[ ! -f "$SESSIONS_FILE" ]]; then
        mkdir -p "$CLUSTER_DIR"
        echo '{"sessions": []}' > "$SESSIONS_FILE"
    fi
}

# Validate session name
validate_session_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        log_error "Invalid session name. Use only alphanumeric characters, hyphens, and underscores."
        exit 1
    fi
}

# Check if session name already exists
session_exists() {
    local name="$1"
    jq -e ".sessions[] | select(.name == \"$name\")" "$SESSIONS_FILE" > /dev/null 2>&1
}

# Check if process is running
is_process_running() {
    local pid="$1"
    ps -p "$pid" > /dev/null 2>&1
}

# Add session to sessions.json
add_session() {
    local name="$1"
    local pid="$2"
    local branch="$3"
    local working_dir="$4"
    local started=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local new_session=$(jq -n \
        --arg name "$name" \
        --arg pid "$pid" \
        --arg branch "$branch" \
        --arg dir "$working_dir" \
        --arg started "$started" \
        '{name: $name, pid: ($pid|tonumber), branch: $branch, working_dir: $dir, started: $started}')

    jq ".sessions += [$new_session]" "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp"
    mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
}

# Remove session from sessions.json
remove_session() {
    local name="$1"
    jq "del(.sessions[] | select(.name == \"$name\"))" "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp"
    mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
}

# Get session by name
get_session() {
    local name="$1"
    jq -r ".sessions[] | select(.name == \"$name\")" "$SESSIONS_FILE"
}

# Clean up stale sessions
cleanup_stale_sessions() {
    local stale_count=0
    local sessions=$(jq -r '.sessions[] | @json' "$SESSIONS_FILE")

    while IFS= read -r session; do
        local pid=$(echo "$session" | jq -r '.pid')
        local name=$(echo "$session" | jq -r '.name')

        if ! is_process_running "$pid"; then
            log_warn "Removing stale session: $name (PID $pid)"
            remove_session "$name"
            ((stale_count++))
        fi
    done <<< "$sessions"

    if [[ $stale_count -gt 0 ]]; then
        log_info "Cleaned up $stale_count stale session(s)"
    fi
}

# Command: start
cmd_start() {
    local name=""
    local branch=""
    local auto_branch=false
    local working_dir="$PWD"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -b|--branch)
                branch="$2"
                shift 2
                ;;
            --auto-branch)
                auto_branch=true
                shift
                ;;
            -d|--dir)
                working_dir="$2"
                shift 2
                ;;
            *)
                name="$1"
                shift
                ;;
        esac
    done

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster start <name> [--branch <branch>] [--auto-branch] [--dir <directory>]"
        exit 1
    fi

    validate_session_name "$name"

    if session_exists "$name"; then
        log_error "Session '$name' already exists. Use 'claude-cluster kill $name' first."
        exit 1
    fi

    # Check if directory exists
    if [[ ! -d "$working_dir" ]]; then
        log_error "Directory does not exist: $working_dir"
        exit 1
    fi

    # Handle git branch with worktrees for true isolation
    local use_worktree=false
    local worktree_dir=""

    if [[ -d "$working_dir/.git" ]] || git -C "$working_dir" rev-parse --git-dir > /dev/null 2>&1; then
        local git_root=$(cd "$working_dir" && git rev-parse --show-toplevel)
        local current_branch=$(cd "$working_dir" && git branch --show-current)

        if [[ "$auto_branch" == true ]]; then
            branch="claude/$name"
            log_info "Auto-creating branch: $branch"
        fi

        if [[ -n "$branch" ]]; then
            use_worktree=true

            # Create worktree directory structure: ~/.claude/cluster/worktrees/<repo-name>/<branch-name>
            local repo_name=$(basename "$git_root")
            worktree_dir="$WORKTREE_BASE/$repo_name/$name"

            log_info "Creating isolated worktree for branch: $branch"
            log_info "Worktree location: $worktree_dir"

            # Create worktree base directory
            mkdir -p "$(dirname "$worktree_dir")"

            # Check if branch exists
            if (cd "$git_root" && git show-ref --verify --quiet "refs/heads/$branch"); then
                log_info "Using existing branch: $branch"
                # Create worktree with existing branch
                (cd "$git_root" && git worktree add "$worktree_dir" "$branch")
            else
                log_info "Creating new branch: $branch"
                # Create worktree with new branch
                (cd "$git_root" && git worktree add -b "$branch" "$worktree_dir")
            fi

            # Update working_dir to point to worktree
            working_dir="$worktree_dir"
        else
            branch="$current_branch"
            log_warn "No branch specified, using current branch in shared directory"
            log_warn "For true isolation, use --auto-branch or --branch"
        fi
    else
        branch="N/A"
        log_warn "Not a git repository: $working_dir"
    fi

    # Launch Claude in the working directory
    log_info "Launching Claude instance: $name"
    log_info "Working directory: $working_dir"
    log_info "Branch: $branch"

    # Use osascript to open new Terminal window/tab
    if [[ "$TERM_PROGRAM" == "Apple_Terminal" ]] || command -v osascript &> /dev/null; then
        osascript <<EOF
tell application "Terminal"
    do script "cd '$working_dir' && echo 'Claude Cluster Session: $name' && echo 'Branch: $branch' && echo '' && $CLAUDE_BIN --model claude-opus-4-6 --dangerously-skip-permissions"
    activate
end tell
EOF
        # Give the terminal a moment to start and get the PID
        sleep 1

        # Find the most recent Claude process
        local claude_pid=$(pgrep -n "claude")

        if [[ -z "$claude_pid" ]]; then
            log_error "Failed to find Claude process. Session may not have started correctly."
            exit 1
        fi

        add_session "$name" "$claude_pid" "$branch" "$working_dir"
        log_success "Started session '$name' (PID: $claude_pid)"
    else
        log_error "Terminal automation not supported. Please launch Claude manually."
        exit 1
    fi
}

# Command: list
cmd_list() {
    cleanup_stale_sessions

    local sessions=$(jq -r '.sessions' "$SESSIONS_FILE")
    local count=$(echo "$sessions" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
        log_info "No active sessions"
        exit 0
    fi

    echo ""
    printf "%-20s %-10s %-30s %-25s %s\n" "NAME" "PID" "BRANCH" "STARTED" "WORKING DIR"
    printf "%-20s %-10s %-30s %-25s %s\n" "----" "---" "------" "-------" "-----------"

    echo "$sessions" | jq -r '.[] | [.name, .pid, .branch, .started, .working_dir] | @tsv' | \
    while IFS=$'\t' read -r name pid branch started dir; do
        printf "%-20s %-10s %-30s %-25s %s\n" "$name" "$pid" "$branch" "$started" "$dir"
    done

    echo ""
    log_info "Total active sessions: $count"
}

# Command: kill
cmd_kill() {
    local name="$1"
    local force=false

    if [[ "$name" == "--all" ]]; then
        # Kill all sessions
        local sessions=$(jq -r '.sessions[] | @json' "$SESSIONS_FILE")
        local count=0

        while IFS= read -r session; do
            if [[ -z "$session" ]]; then
                continue
            fi

            local session_name=$(echo "$session" | jq -r '.name')
            # Use the full kill logic for each session to clean up worktrees
            cmd_kill "$session_name" 2>/dev/null || true
            ((count++))
        done <<< "$sessions"

        log_success "Killed $count session(s)"
        exit 0
    fi

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster kill <name|--all>"
        exit 1
    fi

    if ! session_exists "$name"; then
        log_error "Session '$name' not found"
        exit 1
    fi

    local session=$(get_session "$name")
    local pid=$(echo "$session" | jq -r '.pid')
    local working_dir=$(echo "$session" | jq -r '.working_dir')

    if is_process_running "$pid"; then
        log_info "Killing session '$name' (PID $pid)"
        kill "$pid" 2>/dev/null || log_error "Failed to kill process $pid"
        sleep 1

        if is_process_running "$pid"; then
            log_warn "Process still running, sending SIGKILL"
            kill -9 "$pid" 2>/dev/null
        fi

        log_success "Session '$name' terminated"
    else
        log_warn "Process $pid is not running"
    fi

    # Clean up worktree if it was used
    if [[ "$working_dir" == "$WORKTREE_BASE"* ]]; then
        log_info "Removing worktree: $working_dir"

        # Find the git root for this worktree
        if [[ -d "$working_dir" ]] && git -C "$working_dir" rev-parse --git-dir > /dev/null 2>&1; then
            local git_root=$(cd "$working_dir" && git rev-parse --show-toplevel 2>/dev/null || true)
            local git_common_dir=$(cd "$working_dir" && git rev-parse --git-common-dir 2>/dev/null || true)

            # Get the main repository directory
            if [[ -n "$git_common_dir" ]]; then
                local main_repo=$(dirname "$git_common_dir")
                (cd "$main_repo" && git worktree remove "$working_dir" --force 2>/dev/null || rm -rf "$working_dir")
            fi
        else
            # Worktree directory exists but git is gone, just remove it
            rm -rf "$working_dir"
        fi

        log_success "Worktree cleaned up"
    fi

    remove_session "$name"
}

# Command: status
cmd_status() {
    local name="$1"

    if [[ -z "$name" ]]; then
        log_error "Usage: claude-cluster status <name>"
        exit 1
    fi

    if ! session_exists "$name"; then
        log_error "Session '$name' not found"
        exit 1
    fi

    local session=$(get_session "$name")
    local pid=$(echo "$session" | jq -r '.pid')
    local branch=$(echo "$session" | jq -r '.branch')
    local started=$(echo "$session" | jq -r '.started')
    local dir=$(echo "$session" | jq -r '.working_dir')

    echo ""
    echo "Session: $name"
    echo "PID: $pid"
    echo "Branch: $branch"
    echo "Started: $started"
    echo "Working Dir: $dir"
    echo "Status: $(is_process_running "$pid" && echo "Running" || echo "Not Running")"
    echo ""
}

# Command: help
cmd_help() {
    cat <<EOF
claude-cluster - Manage multiple Claude Code instances

USAGE:
    claude-cluster <command> [options]

COMMANDS:
    start <name>              Start a new Claude instance with given name
        --branch <branch>     Checkout specific git branch (creates isolated worktree)
        --auto-branch         Auto-create branch claude/<name> (creates isolated worktree)
        --dir <directory>     Set working directory (default: current)

    list                      List all active sessions

    kill <name>               Terminate a specific session (cleans up worktree)
    kill --all                Terminate all sessions (cleans up all worktrees)

    status <name>             Show detailed status of a session

    help                      Show this help message

EXAMPLES:
    # Start instance with auto-created branch (RECOMMENDED - creates isolated worktree)
    claude-cluster start feature-auth --auto-branch

    # Start instance on specific branch (creates isolated worktree)
    claude-cluster start bugfix-api --branch fix/api-error

    # List all running instances
    claude-cluster list

    # Kill specific instance (removes worktree)
    claude-cluster kill feature-auth

    # Kill all instances (removes all worktrees)
    claude-cluster kill --all

WORKTREES:
    When using --branch or --auto-branch, claude-cluster creates a git worktree
    at ~/.claude/cluster/worktrees/<repo>/<name>/ for true branch isolation.
    Each instance works in its own directory with its own branch checked out.

MORE INFO:
    See ~/.claude/cluster/README.md for detailed documentation

EOF
}

# Main command dispatcher
main() {
    check_jq
    init_sessions

    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 0
    fi

    local command="$1"
    shift

    case "$command" in
        start)
            cmd_start "$@"
            ;;
        list|ls)
            cmd_list "$@"
            ;;
        kill|stop)
            cmd_kill "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
